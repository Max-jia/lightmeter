# ============================================
# Darkroom — Environment Variables
# 复制此文件为 .env.local 并填入实际值
# ============================================

# Supabase (数据库 + 认证)
# 在 https://supabase.com/dashboard 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# DeepSeek AI (大模型)
# 在 https://platform.deepseek.com 注册后获取
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Stripe (收款)
# 在 https://dashboard.stripe.com 获取
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key

# Google OAuth (Gmail 连接)
# 在 https://console.cloud.google.com 创建 OAuth 2.0 凭据
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe 订阅价格 (在 Stripe Dashboard > Products 中创建后获取)
STRIPE_STANDARD_PRICE_ID=price_xxxxx
STRIPE_PRO_PRICE_ID=price_xxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
